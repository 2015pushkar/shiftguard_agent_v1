# Copy to .env and adjust. All values have safe defaults in config.py;
# every var here is optional. Commands are expected to run from the repo root.

# --- LLM (Ollama) ---
OLLAMA_HOST=http://localhost:11434
# Demo/eval default. Use qwen2.5:3b-instruct for faster dev iteration.
OLLAMA_MODEL=qwen2.5:7b-instruct
# Pin the context window. Ollama defaults to 2048 and SILENTLY truncates oldest
# tokens on overflow, which corrupts a multi-step ReAct loop. Keep this >= 8192.
OLLAMA_CONTEXT_LENGTH=8192
TEMPERATURE=0.0

# --- Embeddings / RAG ---
EMBED_MODEL=nomic-embed-text
TOP_K=3

# --- Agent loop ---
MAX_STEPS=6
MAX_RETRIES=2

# --- Paths (relative paths resolve against the repo root) ---
DATA_DIR=data
QDRANT_DIR=data/qdrant
LOG_DIR=logs
QDRANT_COLLECTION=policies
